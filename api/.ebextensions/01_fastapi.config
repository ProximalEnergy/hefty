option_settings:
  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: "/var/app/current:$PYTHONPATH"
  aws:elasticbeanstalk:container:python:
    WSGIPath: "app.main:app"

commands:
  01_verify_deployment:
    command: |
      echo "=== Verifying deployment structure ==="
      echo "Current directory contents:"
      ls -la /var/app/current/
      echo ""
      echo "Core directory contents:"
      ls -la /var/app/current/core/ || echo 'ERROR: Core library directory not found'
      echo ""
      echo "Core __init__.py exists:"
      test -f /var/app/current/core/__init__.py && echo "YES" || echo "NO - THIS WILL CAUSE IMPORT ERRORS"
      echo ""
      echo "Requirements.txt exists:"
      test -f /var/app/current/requirements.txt && echo "YES" || echo "NO"
      echo ""
      echo "Checking for core in requirements.txt:"
      grep -i "^core" /var/app/current/requirements.txt && echo "WARNING: Core found in requirements.txt!" || echo "Good - no core in requirements"
    ignoreErrors: true
