option_settings:
  aws:elasticbeanstalk:application:environment:
    PYTHONPATH: "/var/app/current:$PYTHONPATH"
  aws:elasticbeanstalk:container:python:
    WSGIPath: "app.main:app"

commands:
  00_install_chromium:
    command: |
      echo "=== Installing Chromium for Kaleido ==="
      if ! command -v chromium >/dev/null 2>&1 \
        && ! command -v chromium-browser >/dev/null 2>&1 \
        && ! command -v google-chrome >/dev/null 2>&1; then
        if ! (dnf install -y \
          libnss3 libatk-bridge2.0-0 libcups2 libxcomposite1 \
          libxdamage1 libxfixes3 libxrandr2 libgbm1 \
          libxkbcommon0 libpango-1.0-0 libcairo2 libasound2 \
          || yum install -y \
          libnss3 libatk-bridge2.0-0 libcups2 libxcomposite1 \
          libxdamage1 libxfixes3 libxrandr2 libgbm1 \
          libxkbcommon0 libpango-1.0-0 libcairo2 libasound2); then
          echo "Chromium dependencies install failed; continuing"
        fi
        if ! (dnf install -y chromium || yum install -y chromium); then
          echo "Chromium install failed; will use Kaleido installer"
        fi
      else
        echo "Chromium/Chrome already installed"
      fi
    ignoreErrors: true
  01_verify_deployment:
    command: |
      echo "=== Verifying deployment structure ==="
      echo "Current directory contents:"
      ls -la /var/app/current/
      echo ""
      echo "Core directory contents:"
      ls -la /var/app/current/core/ || echo 'ERROR: Core library directory not found'
      echo ""
      echo "Core __init__.py exists:"
      test -f /var/app/current/core/__init__.py && echo "YES" || echo "NO - THIS WILL CAUSE IMPORT ERRORS"
      echo ""
      echo "Requirements.txt exists:"
      test -f /var/app/current/requirements.txt && echo "YES" || echo "NO"
      echo ""
      echo "Checking for core in requirements.txt:"
      grep -i "^core" /var/app/current/requirements.txt && echo "WARNING: Core found in requirements.txt!" || echo "Good - no core in requirements"
    ignoreErrors: true

container_commands:
  01_kaleido_get_chrome:
    command: |
      echo "=== Ensuring Kaleido Chrome ==="
      if ! command -v chromium >/dev/null 2>&1 \
        && ! command -v chromium-browser >/dev/null 2>&1 \
        && ! command -v google-chrome >/dev/null 2>&1; then
        installed=0
        for bin in /var/app/venv/*/bin; do
          if [ -x "$bin/kaleido_get_chrome" ]; then
            "$bin/kaleido_get_chrome"
            installed=1
            break
          fi
          if [ -x "$bin/plotly_get_chrome" ]; then
            "$bin/plotly_get_chrome"
            installed=1
            break
          fi
          if [ -x "$bin/python" ]; then
            "$bin/python" -c "import kaleido; kaleido.get_chrome_sync()"
            installed=1
            break
          fi
        done
        if [ "$installed" -eq 0 ]; then
          echo "Kaleido Chrome installer not found in venv"
          exit 1
        fi
      else
        echo "System Chrome already present"
      fi
