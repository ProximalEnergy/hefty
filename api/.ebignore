# IMPORTANT: The core/ directory must be included in deployment
# It contains the bundled core library that is copied during CI/CD

# Python cache and compiled files
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Virtual environments
.venv/
venv/
ENV/
env/
.proxapi

# Git
.git/
.gitignore
.github/

# IDE and editor files
.vscode/
.idea/
.cursor/
*.swp
*.swo
*~

# Testing
_tests/
_pr_checks/
pytest.ini
.pytest_cache/
.coverage
htmlcov/
*.cover

# Documentation and dev files
_docs/
AGENTS.md
DOCKER_BUILD.md
pull_request_template.md
# Keep DEPLOYMENT.md but exclude other markdown
# *.md  # Commented out to allow DEPLOYMENT.md

# Docker files (EB doesn't need these)
Dockerfile
Dockerfile.*
.dockerignore
docker-compose.yml

# Development tools
.pre-commit-config.yaml
.python-version
pyproject.toml
uv.lock
poetry.lock

# Data and notebooks
_data_insert/
*.ipynb
core_test.ipynb

# Debian packages
*.deb

# Build artifacts that we don't need deployed
*.egg-info/
build/
dist/
*.egg

# Smoke testing (runs in CI, not needed on server)
_smoke_testing/
hurl_*

# Elastic Beanstalk local config
.elasticbeanstalk/

# Mac
.DS_Store

# Environment files (these should be set in EB environment)
.env
.env.*
.env_backup

# Sandbox and temp files
sandbox/
*.log
*.tmp

# Scripts that are only needed during build/deploy
_scripts/
