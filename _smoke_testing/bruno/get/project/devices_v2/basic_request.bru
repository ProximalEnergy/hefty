meta {
  name: basic_request
  type: http
  seq: 3
}

post {
  url: {{baseURL}}/v1/operational/projects/3b63ea38-cf28-4880-810e-41a81209d640/devices/
  body: json
  auth: inherit
}

body:json {
  {
    "device_ids": [],
    "device_type_ids": [1,13,17,25,27,31,32,33,34],
    "parent_device_ids": [],
    "name_short": "",
    "name_long": "",
    "device_id_descendent_of": null,
    "deep": false,
    "with_tags": false,
    "limit": 1000,
    "offset": 0,
    "format": "json"
  }
}

tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("Response is an array", function() {
    expect(res.getBody()).to.be.an('array');
  });
  
  test("Response contains expected device fields", function() {
    const body = res.getBody();
    if (body.length > 0) {
      const device = body[0];
      expect(device).to.have.property('device_id');
      expect(device).to.have.property('device_type_id');
      expect(device).to.have.property('name_short');
      expect(device).to.have.property('name_long');
      expect(device).to.have.property('name_full');
      expect(device).to.have.property('parent_device_id');
    }
  });
  
  test("Response respects limit parameter", function() {
    const body = res.getBody();
    expect(body.length).to.be.at.most(10);
  });
  
  test("name_full field is properly constructed", function() {
    const body = res.getBody();
    if (body.length > 0) {
      const device = body[0];
      expect(device.name_full).to.be.a('string');
      // name_full should contain device type name and device name
      expect(device.name_full.length).to.be.greaterThan(0);
    }
  });
}
