tests {
  test("Status is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("Response is an array", function() {
    expect(res.getBody()).to.be.an('array');
  });
  
  test("Response contains expected fields", function() {
    const body = res.getBody();
    if (body.length > 0) {
      expect(body[0]).to.have.property('tag_id');
      expect(body[0]).to.have.property('time');
      expect(body[0]).to.have.property('age');
      expect(body[0]).to.have.property('sensor_type_id');
      expect(body[0]).to.have.property('device_id');
      expect(body[0]).to.have.property('device_type_id');
      expect(body[0]).to.have.property('device_name');
      expect(body[0]).to.have.property('stale');
      expect(body[0]).to.have.property('age_pct');
    }
  });
}
