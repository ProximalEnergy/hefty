{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "semi": false,
  "importOrder": ["^@core/(.*)$", "^@server/(.*)$", "^@ui/(.*)$", "^[./]"],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "printWidth": 80,
  "sortPackageJson": false,
  "ignorePatterns": [
    ".vscode-test/",
    "out/",
    "dist/",
    "test-fixtures/",
    "node_modules/",
    "src/api/enumerations.ts",
    "src/api/schema.d.ts"
  ]
}
