{
  "name": "web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --force",
    "build": "tsgo && NODE_OPTIONS=--max_old_space_size=8192 vite build",
    "lint": "oxlint --deny-warnings --report-unused-disable-directives",
    "lint:github": "oxlint --deny-warnings --report-unused-disable-directives --format=github",
    "preview": "vite preview",
    "typecheck": "pnpm exec tsgo --noEmit",
    "prettier": "pnpm exec prettier --write --log-level warn .",
    "prettier:check": "pnpm exec prettier --check --log-level warn .",
    "knip": "pnpm exec knip",
    "check:bulletproof-react": "node scripts/check-bulletproof-react.mjs",
    "check": "pnpm run typecheck && pnpm run prettier:check && pnpm run knip && pnpm run check:bulletproof-react"
  },
  "dependencies": {
    "@clerk/react": "^6.1.0",
    "@clerk/themes": "^2.4.46",
    "@dnd-kit/core": "^6.0.8",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.1",
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/daygrid": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/list": "^6.1.17",
    "@fullcalendar/react": "^6.1.17",
    "@fullcalendar/rrule": "^6.1.17",
    "@mantine/core": "^9.1.1",
    "@mantine/dates": "^9.1.1",
    "@mantine/dropzone": "^9.1.1",
    "@mantine/form": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@mantine/spotlight": "^9.1.1",
    "@mantine/tiptap": "^9.1.1",
    "@openai/agents-realtime": "^0.7.0",
    "@posthog/react": "^1.7.1",
    "@sentry/react": "^10.38.0",
    "@sentry/vite-plugin": "^4.9.0",
    "@tabler/icons-react": "^3.31.0",
    "@tanstack/react-query": "^5.67.3",
    "@tanstack/react-query-devtools": "^5.67.3",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.13.2",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/pm": "^3.22.5",
    "@tiptap/react": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@xyflow/react": "^12.8.1",
    "apache-arrow": "^21.0.0",
    "axios": "^1.8.2",
    "chroma-js": "^3.1.2",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.13",
    "dompurify": "^3.2.7",
    "geojson": "^0.5.0",
    "html2canvas-pro": "^1.6.3",
    "jspdf": "^4.0.0",
    "lodash": "^4.17.21",
    "mapbox-gl": "^3.10.0",
    "markdown-it": "^14.1.0",
    "pdf-lib": "~1.17.1",
    "plotly.js": "~3.5.0",
    "posthog-js": "^1.347.2",
    "qs": "^6.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-grid-layout": "^2.2.3",
    "react-map-gl": "^8.1.0",
    "react-pdf": "^10.3.0",
    "react-plotly.js": "^2.6.0",
    "react-resizable": "^3.0.5",
    "react-router": "^7.9.4",
    "rrule": "^2.8.1",
    "uuid": "^13.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/chroma-js": "^3.1.2",
    "@types/geojson": "^7946.0.16",
    "@types/lodash": "^4.17.16",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.9.2",
    "@types/plotly.js": "^3.0.8",
    "@types/qs": "^6.9.18",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@types/react-plotly.js": "^2.6.3",
    "@typescript/native-preview": "7.0.0-dev.20260514.1",
    "@vitejs/plugin-react-swc": "^4.2",
    "knip": "^5.66.0",
    "openapi-typescript": "^7.10.1",
    "oxlint": "^1.50.0",
    "oxlint-tsgolint": "^0.19.0",
    "postcss": "^8.5.3",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^6.0.5",
    "typescript": "^5.9.2",
    "vite": "^7.2.2"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@types/mapbox__point-geometry": "npm:@mapbox/point-geometry@^1.1.0"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": false,
    "plugins": [
      "@trivago/prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "^@core/(.*)$",
      "^@server/(.*)$",
      "^@ui/(.*)$",
      "^[./]"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
  },
  "packageManager": "pnpm@10.33.2"
}
