{
  "name": "web-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node build-plotly-custom.js && tsc && vite build",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "check": "npx tsc && npx prettier --write --log-level warn .",
    "test": "npx playwright test",
    "generate:types": "openapi-typescript ../api/openapi.json --output ./src/api/_example/openapi-typescript/api-types.ts",
    "generate:enums": "node ./scripts/generate-enums.mjs ../api/openapi.json ./src/api/_example/openapi-typescript/enums.ts",
    "generate-api": "npm run generate:types && npm run generate:enums"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.24.1",
    "@clerk/themes": "^2.2.20",
    "@dnd-kit/core": "^6.0.8",
    "@dnd-kit/sortable": "^7.0.2",
    "@dnd-kit/utilities": "^3.2.1",
    "@fullcalendar/core": "^6.1.17",
    "@fullcalendar/daygrid": "^6.1.17",
    "@fullcalendar/interaction": "^6.1.17",
    "@fullcalendar/list": "^6.1.17",
    "@fullcalendar/react": "^6.1.17",
    "@fullcalendar/rrule": "^6.1.17",
    "@fullcalendar/timegrid": "^6.1.17",
    "@mantine/core": "^7.17.8",
    "@mantine/dates": "^7.17.1",
    "@mantine/dropzone": "^7.17.1",
    "@mantine/form": "^7.17.1",
    "@mantine/hooks": "^7.17.8",
    "@mantine/notifications": "^7.17.1",
    "@mantine/spotlight": "^7.17.1",
    "@mantine/tiptap": "^7.17.8",
    "@openai/agents": "^0.1.0",
    "@openai/agents-core": "^0.1.0",
    "@openai/agents-openai": "^0.1.0",
    "@openai/agents-realtime": "^0.1.0",
    "@react-pdf-viewer/core": "^3.12.0",
    "@react-pdf-viewer/default-layout": "^3.12.0",
    "@react-pdf-viewer/search": "^3.12.0",
    "@sentry/react": "^7.120.3",
    "@sentry/vite-plugin": "^2.23.0",
    "@tabler/icons-react": "^3.31.0",
    "@tanstack/react-query": "^5.67.3",
    "@tanstack/react-query-devtools": "^5.67.3",
    "@tanstack/react-virtual": "^3.13.2",
    "@tiptap/extension-link": "^2.26.1",
    "@tiptap/pm": "^2.26.1",
    "@tiptap/react": "^2.26.1",
    "@tiptap/starter-kit": "^2.26.1",
    "@types/dompurify": "^3.2.0",
    "@xyflow/react": "^12.8.1",
    "apache-arrow": "^21.0.0",
    "axios": "^1.8.2",
    "chroma-js": "^3.1.2",
    "dayjs": "^1.11.13",
    "dompurify": "^3.2.7",
    "lodash": "^4.17.21",
    "mantine-react-table": "^2.0.0-beta.9",
    "mapbox-gl": "^3.10.0",
    "markdown-it": "^14.1.0",
    "pdfjs-dist": "^3.11.174",
    "plotly.js": "^2.35.3",
    "qs": "^6.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-grid-layout": "^1.5.1",
    "react-map-gl": "^7.1.9",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^6.30.0",
    "rrule": "^2.8.1",
    "uuid": "^10.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tanstack/eslint-plugin-query": "^5.67.2",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/chroma-js": "^2.4.5",
    "@types/lodash": "^4.17.16",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.13.10",
    "@types/plotly.js": "^2.35.2",
    "@types/qs": "^6.9.18",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-plotly.js": "^2.6.3",
    "@types/rrule": "^2.1.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.19",
    "install": "^0.13.0",
    "npm": "^11.3.0",
    "openapi-typescript": "^7.9.1",
    "playwright": "^1.55.0",
    "postcss": "^8.5.3",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^5.14.0",
    "typescript": "^5.9.2",
    "vite": "^6.3.4"
  },
  "prettier": {
    "singleQuote": true,
    "trailingComma": "all",
    "tabWidth": 2,
    "semi": false,
    "plugins": [
      "@trivago/prettier-plugin-sort-imports"
    ],
    "importOrder": [
      "^@core/(.*)$",
      "^@server/(.*)$",
      "^@ui/(.*)$",
      "^[./]"
    ],
    "importOrderSeparation": true,
    "importOrderSortSpecifiers": true
  }
}