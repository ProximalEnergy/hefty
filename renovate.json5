{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  dependencyDashboard: true,
  minimumReleaseAge: "30 days",
  internalChecksFilter: "strict",
  reviewers: ["kurt-rhee"],
  schedule: ["* 5-12 * * 1"],
  timezone: "America/Los_Angeles",
  description: "Schedule Monday at 5 AM Pacific",
  packageRules: [
    // =========== Don't Upgrade Python ============
    {
      matchDatasources: ["python-version"],
      enabled: false,
    },
    {
      matchPackageNames: ["python"],
      matchDatasources: ["docker", "github-tags", "github-runners", "github-releases"],
      enabled: false,
    },
    {
      matchPackageNames: ["python/cpython"],
      matchDatasources: ["github-tags"],
      enabled: false,
    },
    {
      matchPackageNames: ["actions/python-versions"],
      enabled: false
    },
    // =========== Group Upgrades by Service ============
    {
      matchFileNames: ["api/**"],
      groupName: "api",
    },
    {
      matchFileNames: ["core/**"],
      groupName: "core",
    },
    {
      matchFileNames: ["web-app/**"],
      groupName: "web-app",
    },
    {
      matchFileNames: ["docs-mdbook/**"],
      groupName: "docs-mdbook",
    },
    {
      matchFileNames: ["microservices/**"],
      groupName: "microservices",
    },
    {
      matchFileNames: ["sql-admin/**"],
      groupName: "sql-admin",
    },
    {
      matchFileNames: ["pv-eem/**"],
      groupName: "pv-eem",
    },
  ],
}
