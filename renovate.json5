{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:recommended"],
  dependencyDashboard: true,
  minimumReleaseAge: "30 days",
  internalChecksFilter: "strict",
  separateMajorMinor: true,
  reviewers: ["kurt-rhee"],
  schedule: ["* 5-12 1 * *"],
  timezone: "America/Los_Angeles",
  description: "Schedule on the first of the month at 5 AM Pacific",
  ignorePaths: [
    "**/requirements.txt",
    "third-party/**",
  ],
  packageRules: [
    // =========== Don't Upgrade Python ============
    {
      matchDatasources: ["python-version"],
      enabled: false,
    },
    {
      matchPackageNames: ["python"],
      matchDatasources: [
        "docker",
        "github-tags",
        "github-releases",
      ],
      enabled: false,
    },
    {
      matchPackageNames: ["python/cpython"],
      matchDatasources: ["github-tags"],
      enabled: false,
    },
    {
      matchPackageNames: ["actions/python-versions"],
      enabled: false,
    },
    // =========== Group GitHub Actions ============
    {
      groupName: "github-actions",
      matchManagers: ["github-actions"],
    },
    // =========== Group Upgrades by Service ============
    {
      groupName: "root",
      matchFileNames: [
        "pyproject.toml",
        ".mise.toml",
        ".pre-commit-config.yaml",
      ],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "core",
      matchFileNames: ["core/**"],
      matchPackageNames: [
        "*",
        "!fastapi",
      ],
      reviewers: ["kurt-rhee"],
    },
    {
      matchFileNames: ["core/**"],
      matchPackageNames: ["fastapi"],
      enabled: false,
    },
    {
      groupName: "api",
      matchFileNames: ["api/**"],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "web-app",
      matchFileNames: ["web-app/**"],
      reviewers: ["hunter-proximal"],
    },
    {
      groupName: "mobile",
      matchFileNames: ["mobile/**"],
      reviewers: ["hunter-proximal"],
    },
    {
      groupName: "docs-mdbook",
      matchFileNames: ["docs-mdbook/**"],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "kpi",
      matchFileNames: ["kpi/**"],
      reviewers: ["davidthemathman"],
    },
    {
      groupName: "microservices/calendar_notifications_lambda",
      matchFileNames: ["microservices/calendar_notifications_lambda/**"],
      reviewers: ["Robiemaan"],
    },
    {
      groupName: "microservices/cdk",
      matchFileNames: ["microservices/cdk/**"],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "microservices/cmms-integration-fetcher",
      matchFileNames: ["microservices/cmms-integration-fetcher/**"],
      reviewers: ["davidthemathman"],
    },
    {
      groupName: "microservices/cmms-ticket-download",
      matchFileNames: ["microservices/cmms-ticket-download/**"],
      reviewers: ["davidthemathman"],
    },
    {
      groupName: "microservices/data_connection_outage_notifications_lambda",
      matchFileNames: [
        "microservices/data_connection_outage_notifications_lambda/**",
      ],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "microservices/issues_pipeline_lambda",
      matchFileNames: ["microservices/issues_pipeline_lambda/**"],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "microservices/weather_alerts_lambda",
      matchFileNames: ["microservices/weather_alerts_lambda/**"],
      reviewers: ["Robiemaan"],
    },
    {
      groupName: "forecast",
      matchFileNames: ["forecast/**"],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "issues",
      matchFileNames: ["issues/**"],
      reviewers: ["hunter-proximal"],
    },
    {
      groupName: "pv-eem",
      matchFileNames: ["pv-eem/**"],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "super-admin/inspectui",
      matchFileNames: ["super-admin/inspectui/**"],
      reviewers: ["davidthemathman"],
    },
    {
      groupName: "super-admin/kpi-dep-app",
      matchFileNames: ["super-admin/kpi-dep-app/**"],
      reviewers: ["davidthemathman"],
    },
    {
      groupName: "super-admin/meta",
      matchFileNames: ["super-admin/meta/**"],
      reviewers: ["kurt-rhee"],
    },
    {
      groupName: "super-admin/uploaded-documents",
      matchFileNames: ["super-admin/uploaded-documents/**"],
      reviewers: ["marcus-maro"],
    },
  ],
}
